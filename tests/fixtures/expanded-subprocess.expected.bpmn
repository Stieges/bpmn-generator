      <bpmn:endEvent id="sub1_end" name="Ende" />
      <bpmn:sequenceFlow id="sub1_f1" sourceRef="sub1_start" targetRef="sub1_task1" />
      <bpmn:sequenceFlow id="sub1_f2" sourceRef="sub1_task1" targetRef="sub1_task2" />
      <bpmn:sequenceFlow id="sub1_f3" sourceRef="sub1_task2" targetRef="sub1_end" />
    </bpmn:subProcess>
    <bpmn:endEvent id="end1" name="Abgeschlossen">
