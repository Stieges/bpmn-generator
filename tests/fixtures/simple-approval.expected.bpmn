<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Process_Main" name="Main Pool" processRef="Process_Main" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Main" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_Main">
      <bpmn:lane id="lane1" name="Default Lane">
        <bpmn:flowNodeRef>start1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start1" name="Start">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="task1" name="Review Document">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw1" name="Approved?" gatewayDirection="Diverging" default="f4">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task2" name="Process Approval">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="task3" name="Revise Document">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="end1" name="End">
      <bpmn:incoming>f6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="start1" targetRef="task1" />
    <bpmn:sequenceFlow id="f2" sourceRef="task1" targetRef="gw1" />
    <bpmn:sequenceFlow id="f3" name="Yes" sourceRef="gw1" targetRef="task2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Yes</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f4" name="No" sourceRef="gw1" targetRef="task3" />
    <bpmn:sequenceFlow id="f5" sourceRef="task3" targetRef="task1" />
    <bpmn:sequenceFlow id="f6" sourceRef="task2" targetRef="end1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_Process_Main_di" bpmnElement="Participant_Process_Main" isHorizontal="true">
        <dc:Bounds x="20" y="20" width="692" height="295" />
