        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="110.4" y="220" />
        <di:waypoint x="176" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="276" y="207" />
        <di:waypoint x="296" y="207" />
        <di:waypoint x="296" y="103" />
        <di:waypoint x="329" y="103" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
