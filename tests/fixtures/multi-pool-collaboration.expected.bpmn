<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Process_Customer" name="Customer" processRef="Process_Customer" />
    <bpmn:participant id="Participant_Process_Service" name="Service Department" processRef="Process_Service" />
    <bpmn:messageFlow id="mf1" name="Request" sourceRef="c_submit" targetRef="s_start" />
    <bpmn:messageFlow id="mf2" name="Response" sourceRef="s_merge" targetRef="c_wait" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_Customer">
      <bpmn:lane id="c_lane" name="Customer">
        <bpmn:flowNodeRef>c_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_submit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_wait</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>c_end</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="c_start" name="Need identified">
      <bpmn:outgoing>cf1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sendTask id="c_submit" name="Submit request">
      <bpmn:incoming>cf1</bpmn:incoming>
      <bpmn:outgoing>cf2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="c_wait" name="Wait for response">
      <bpmn:incoming>cf2</bpmn:incoming>
      <bpmn:outgoing>cf3</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:endEvent id="c_end" name="End">
      <bpmn:incoming>cf3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="cf1" sourceRef="c_start" targetRef="c_submit" />
    <bpmn:sequenceFlow id="cf2" sourceRef="c_submit" targetRef="c_wait" />
    <bpmn:sequenceFlow id="cf3" sourceRef="c_wait" targetRef="c_end" />
  </bpmn:process>
  <bpmn:process id="Process_Service" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_Service">
      <bpmn:lane id="s_agent" name="Agent">
        <bpmn:flowNodeRef>s_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>s_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>s_gw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>s_reject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>s_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>s_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="s_mgr" name="Manager">
        <bpmn:flowNodeRef>s_approve</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="s_start" name="Request received">
      <bpmn:outgoing>sf1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="s_review" name="Review request">
      <bpmn:incoming>sf1</bpmn:incoming>
      <bpmn:outgoing>sf2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="s_gw" name="Valid?" gatewayDirection="Diverging" default="sf4">
      <bpmn:incoming>sf2</bpmn:incoming>
      <bpmn:outgoing>sf3</bpmn:outgoing>
      <bpmn:outgoing>sf4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="s_approve" name="Process approval">
      <bpmn:incoming>sf3</bpmn:incoming>
      <bpmn:outgoing>sf5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="s_reject" name="Send rejection">
      <bpmn:incoming>sf4</bpmn:incoming>
      <bpmn:outgoing>sf6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="s_merge" name="" gatewayDirection="Converging">
      <bpmn:incoming>sf5</bpmn:incoming>
      <bpmn:incoming>sf6</bpmn:incoming>
      <bpmn:outgoing>sf7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="s_end" name="End">
      <bpmn:incoming>sf7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="sf1" sourceRef="s_start" targetRef="s_review" />
    <bpmn:sequenceFlow id="sf2" sourceRef="s_review" targetRef="s_gw" />
    <bpmn:sequenceFlow id="sf3" name="Yes" sourceRef="s_gw" targetRef="s_approve">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Yes</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" name="No" sourceRef="s_gw" targetRef="s_reject" />
    <bpmn:sequenceFlow id="sf5" sourceRef="s_approve" targetRef="s_merge" />
    <bpmn:sequenceFlow id="sf6" sourceRef="s_reject" targetRef="s_merge" />
    <bpmn:sequenceFlow id="sf7" sourceRef="s_merge" targetRef="s_end" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
