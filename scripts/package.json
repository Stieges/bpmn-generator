{
  "name": "bpmn-generator",
  "version": "3.1.0",
  "description": "Enterprise BPMN 2.0 Generator — JSON Logic-Core → ElkJS Layout → OMG-compliant XML + SVG",
  "type": "module",
  "license": "MIT",
  "author": "Daniel Stiegler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stieges/bpmn-generator.git"
  },
  "keywords": [
    "bpmn",
    "bpmn2",
    "process",
    "diagram",
    "workflow",
    "elkjs",
    "layout",
    "svg",
    "xml",
    "omg",
    "modeler"
  ],
  "main": "pipeline.js",
  "exports": {
